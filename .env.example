# Supabase credentials
# Create a project at https://supabase.com → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Strava API credentials
# Create an app at https://www.strava.com/settings/api
EXPO_PUBLIC_STRAVA_CLIENT_ID=your_strava_client_id
EXPO_PUBLIC_STRAVA_CLIENT_SECRET=your_strava_client_secret

# Claude API Configuration
# Get your API key from: https://console.anthropic.com/settings/keys
EXPO_PUBLIC_CLAUDE_API_KEY=your_claude_api_key_here

# OpenAI API Configuration
# Get your API key from: https://platform.openai.com/api-keys
EXPO_PUBLIC_OPENAI_API_KEY=your_openai_api_key_here

# Note: Copy this file to .env and fill in real values.
# The .env file is gitignored and will NOT be committed.
